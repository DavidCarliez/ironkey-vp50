post_install() {
  cat <<'EOF'
IronKey VP50 is installed.

Command-line use:
  ironkey-vp50 status
  sudo ironkey-vp50 unlock --sg /dev/sg0 --pvc
  ironkey-vp50 mount

Desktop auto-unlock setup is opt-in because it writes sudoers, udev, and
per-user autostart files:
  sudo ironkey-vp50-install-desktop
EOF
}

post_upgrade() {
  post_install
}
